<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".BienvenidaActivity">

    <!-- Scroll principal -->
    <ScrollView
        android:id="@+id/scrollPrincipal"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="30dp">

            <!-- Hola Usuario -->
            <TextView
                android:id="@+id/tvSaludo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hola, Usuario"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Pregunta -->
            <TextView
                android:id="@+id/tvPregunta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¿Qué deseas pedir hoy?"
                android:textSize="16sp"
                android:layout_marginBottom="24dp" />

            <!-- Botones principales -->

            <Button
                android:id="@+id/btnVerLocales"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ver locales"
                android:layout_marginBottom="12dp"
                android:padding="14dp"
                android:backgroundTint="@color/wine"/>

            <Button
                android:id="@+id/btnMisPedidos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mis pedidos"
                android:layout_marginBottom="12dp"
                android:padding="14dp"
                android:backgroundTint="@color/background"/>

            <Button
                android:id="@+id/btnPedidoEspecial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pedido especial"
                android:layout_marginBottom="12dp"
                android:padding="14dp"
                android:backgroundTint="@color/background"/>

            <Button
                android:id="@+id/btnCerrarSesion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cerrar sesión"
                android:layout_marginBottom="24dp"
                android:padding="14dp"
                android:backgroundTint="@color/background"/>

            <!-- Locales destacados -->
            <TextView
                android:id="@+id/tvDestacados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Locales destacados"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Local 1 -->
                    <LinearLayout
                        android:id="@+id/local1"
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/imgLocal1"
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/logo_ues" />

                        <TextView
                            android:id="@+id/tvLocal1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Cafetín Central" />

                        <TextView
                            android:id="@+id/tvMenu1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Ver menú"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- Local 2 -->
                    <LinearLayout
                        android:id="@+id/local2"
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/imgLocal2"
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/logo_ues" />

                        <TextView
                            android:id="@+id/tvLocal2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Cafetín Ingeniería" />

                        <TextView
                            android:id="@+id/tvMenu2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Ver menú"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>

            </HorizontalScrollView>

            <!-- Lista locales -->
            <TextView
                android:id="@+id/tvLocales"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Locales"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnLocalCentral"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cafetín Central"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/background"/>

            <Button
                android:id="@+id/btnLocalIngenieria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cafetín Ingeniería"
                android:backgroundTint="@color/background"/>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>