<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LocalesActivity">

    <!-- Barra superior -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/wine"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Flecha atrás -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Volver"/>

        <!-- Título -->
        <TextView
            android:id="@+id/tvTituloLocales"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Locales"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginStart="16dp"/>

    </LinearLayout>

    <!-- Scroll contenido -->
    <ScrollView
        android:id="@+id/scrollLocales"
        android:layout_width="0dp"
        android:layout_height="0dp"

        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Texto superior -->
            <TextView
                android:id="@+id/tvIndicacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Seleccione un cafetín para ver su menú"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <!-- CARD LOCAL -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLocal1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"

                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:id="@+id/local1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <!-- Imagen -->
                    <ImageView
                        android:id="@+id/imgLocal"
                        android:layout_width="100dp"
                        android:layout_height="80dp"
                        android:scaleType="centerCrop"
                        tools:src="@drawable/logo_ues" />

                    <!-- Contenido derecho -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <!-- Nombre -->
                        <TextView
                            android:id="@+id/tvNombreLocal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cafetín Central"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <!-- Ubicación -->
                        <TextView
                            android:id="@+id/tvUbicacion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Ubicación: Plaza central"
                            android:textSize="13sp" />

                        <!-- Estado -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:layout_marginEnd="6dp"
                                android:background="@android:color/holo_green_dark" />

                            <TextView
                                android:id="@+id/tvEstado"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Estado: Activo"
                                android:textSize="13sp" />

                        </LinearLayout>

                        <!-- Ver menú -->
                        <TextView
                            android:id="@+id/tvVerMenu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Ver menú >"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>